{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    // baseUrl is required for the "@/*" -> "../user/src/*" alias below; silence the
    // TS7.0 deprecation notice while keeping the behavior the app depends on.
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "react": [
        "./node_modules/@types/react"
      ],
      "react/jsx-runtime": [
        "./node_modules/@types/react/jsx-runtime"
      ],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime"
      ],
      "react/*": [
        "./node_modules/@types/react/*"
      ],
      "react-dom": [
        "./node_modules/@types/react-dom"
      ],
      "react-dom/*": [
        "./node_modules/@types/react-dom/*"
      ],
      "next": [
        "./node_modules/next"
      ],
      "next/*": [
        "./node_modules/next/*"
      ],
      "lucide-react": [
        "./node_modules/lucide-react"
      ],
      "lucide-react/*": [
        "./node_modules/lucide-react/*"
      ],
      "framer-motion": [
        "./node_modules/framer-motion"
      ],
      "framer-motion/*": [
        "./node_modules/framer-motion/*"
      ],
      "jszip": [
        "./node_modules/jszip"
      ],
      "axios": [
        "./node_modules/axios"
      ],
      "jose": [
        "./node_modules/jose"
      ],
      "react-markdown": [
        "./node_modules/react-markdown"
      ],
      "recharts": [
        "./node_modules/recharts"
      ],
      "zod": [
        "./node_modules/zod"
      ],
      "zustand": [
        "./node_modules/zustand"
      ],
      "zustand/*": [
        "./node_modules/zustand/*"
      ],
      "@supabase/ssr": [
        "./node_modules/@supabase/ssr"
      ],
      "@supabase/supabase-js": [
        "./node_modules/@supabase/supabase-js"
      ],
      "@/*": [
        "../user/src/*"
      ],
      "@interviewer/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../user/src/components/Interviewer*.tsx",
    "../user/src/components/StudySetup.tsx",
    "../user/src/store.ts",
    "../user/src/types.ts",
    "../user/src/services/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
