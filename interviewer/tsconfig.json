{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["../user/src/*"],
      "@interviewer/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "../user/src/components/Interviewer*.tsx",
    "../user/src/components/StudySetup.tsx",
    "../user/src/store.ts",
    "../user/src/types.ts",
    "../user/src/services/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
